  renderVals() {
    const lang = this.state.lang;
    const t = this.content()[lang];
    const isAr = lang === 'ar';
    const clients = ['NEXORA','VAULT','HELIOS','QUBIT','MERIDIAN','STRATOS','ORBIT','LUMEN'];
    return {
      t,
      dir: isAr ? 'rtl' : 'ltr',
      ls: isAr ? 'normal' : '0.18em',
      navLs: isAr ? 'normal' : '0.06em',
      langBtn: isAr ? 'EN' : 'ع',
      arrow: isAr ? '\u2190' : '\u2192',
      toggleLang: this.toggleLang,
      clientsLoop: [...clients, ...clients]
    };
  }
}
